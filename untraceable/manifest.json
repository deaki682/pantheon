{
  "manifest_version": 3,
  "name": "UnTraceable — Erase Photo Location & EXIF",
  "version": "1.0.0",
  "description": "Erase the hidden GPS location, device ID & metadata from your JPEG, PNG & WebP photos. 100% on your device — nothing is uploaded.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "UnTraceable — erase photo metadata",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
