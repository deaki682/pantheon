{
  "manifest_version": 3,
  "name": "MetaStrip — Photo Metadata & EXIF Remover",
  "version": "1.0.0",
  "description": "Remove GPS, EXIF & hidden metadata from JPEG, PNG & WebP photos. 100% offline — nothing is uploaded. No permissions.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "MetaStrip — remove photo metadata",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
